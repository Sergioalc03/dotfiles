{
	"pulseaudio":{
		"format": "{icon} {volume}%",
		"format-muted": "¯╗¿",
		"format-icons":{
			"default": ["´ÇĞ", "´Çğ", "´Ç¿"]
		},
		
		"on-click": "pavucontrol",
		"on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_SINK@ 0.05+",
		"on-scroll-down": "wpctl set-volume @DEFAULT_SINK@ 0.05-",
		"tooltip-format": "Volumen"
	}
}
